{
	"extends": "../../tsconfig.json",
	"include": [
		".",
		"next-env.d.ts",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
	],
	"exclude": [
		".private/",
		".next/",
		"node_modules/"
	],
	"compilerOptions": {
		"jsx": "react-jsx",
		"paths": {
			"@/*": ["./*"]
		},
		"plugins": [
			{
				"name": "next"
			}
		]
	}
}
