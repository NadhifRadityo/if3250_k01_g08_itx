{
	"$schema": "https://turborepo.dev/schema.json",
	"extends": ["//"],
	"tasks": {
		"turbo:build": {
			"env": [
				"NEXT_PUBLIC_*"
			],
			"outputs": [
				".next/**",
				"!.next/dev/**"
			]
		},
		"turbo:develop": {
			"with": [
				"turbo:develop:dev"
			]
		},
		"turbo:develop:dev": {
			"cache": false,
			"persistent": true
		}
	}
}
